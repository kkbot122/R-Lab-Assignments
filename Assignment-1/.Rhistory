# Q1. Retail Store Profit Analysis
# A retail store sold 850 products in a month. The selling price of each product is ₹1,250, and the cost price is ₹950.
# Tasks:
# Create R objects for selling price, cost price, and quantity sold.
# Calculate total revenue, total cost, and total profit.
# Display all results using the R console.
# Save the script as Retail_Profit.R.
# creating objects
quantity_sold <- 850
selling_price <- 1250
cost_price <- 950
# calculate results
total_revenue <- selling_price * quantity_sold
total_cost <- cost_price * quantity_sold
total_profit <- total_revenue - total_cost
# print results
cat("Total Revenue:", total_revenue)
cat("Total Cost:", total_cost)
cat("Total profit:", total_profit)
